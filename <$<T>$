local function apply_spin_settings()
    local refs = vars.anti_aim.references.elements

    if refs.pitch and refs.pitch[1] then
        refs.pitch[1]:set("Custom")
    end
    if refs.yaw and refs.yaw[1] then
        refs.yaw[1]:set("Spin")
    end
    if refs.yaw and refs.yaw[2] then
        refs.yaw[2]:set(20)
    end
    if refs.yawjitter and refs.yawjitter[1] then
        refs.yawjitter[1]:set("Off")
    end
    if refs.yawjitter and refs.yawjitter[2] then
        refs.yawjitter[2]:set(0)
    end
    if refs.bodyyaw and refs.bodyyaw[1] then
        refs.bodyyaw[1]:set("Static")
    end
    if refs.bodyyaw and refs.bodyyaw[2] then
        refs.bodyyaw[2]:set(1)
    end
    if refs.fake_lag and refs.fake_lag.limit then
        refs.fake_lag.limit:set(1)
    end

    spin_active = true
end

local function handle_spin_features(cmd)
    local local_player = entity.get_local_player()
    if not local_player then 
        restore_spin_settings()
        return 
    end

    if not entity.is_alive(local_player) then
        restore_spin_settings()
        return
    end

    local features = menu.anti_aim.options:get()
    if not features then
        restore_spin_settings()
        return
    end

    local has_spin_on_warmup = false
    local fast_ladder = false

    for _, feature in ipairs(features) do
        if feature == "Spin on warmup" then
            has_spin_on_warmup = true
        elseif feature == "Fast ladder" then
            fast_ladder = true
        end
    end

    if fast_ladder then
        local pitch, yaw = client.camera_angles()
        local move_type = entity.get_prop(local_player, "m_MoveType")
        
        if move_type == 9 then
            cmd.yaw = math.floor(cmd.yaw + 0.5)
            cmd.roll = 0

            if cmd.forwardmove == 0 then
                if cmd.sidemove ~= 0 then
                    cmd.pitch = 89
                    cmd.yaw = cmd.yaw + 180
                    if cmd.sidemove < 0 then
                        cmd.in_moveleft = 0
                        cmd.in_moveright = 1
                    end
                    if cmd.sidemove > 0 then
                        cmd.in_moveleft = 1
                        cmd.in_moveright = 0
                    end
                end
            end

            if cmd.forwardmove > 0 then
                if pitch < 45 then
                    cmd.pitch = 89
                    cmd.in_moveright = 1
                    cmd.in_moveleft = 0
                    cmd.in_forward = 0
                    cmd.in_back = 1
                    if cmd.sidemove == 0 then
                        cmd.yaw = cmd.yaw + 90
                    end
                    if cmd.sidemove < 0 then
                        cmd.yaw = cmd.yaw + 150
                    end
                    if cmd.sidemove > 0 then
                        cmd.yaw = cmd.yaw + 30
                    end
                end
            end

            if cmd.forwardmove < 0 then
                cmd.pitch = 89
                cmd.in_moveleft = 1
                cmd.in_moveright = 0
                cmd.in_forward = 1
                cmd.in_back = 0

                if cmd.sidemove == 0 then
                    cmd.yaw = cmd.yaw + 90
                end

                if cmd.sidemove > 0 then
                    cmd.yaw = cmd.yaw + 150
                end

                if cmd.sidemove < 0 then
                    cmd.yaw = cmd.yaw + 30
                end
            end
        end
    end
    
    local should_spin = has_spin_on_warmup and is_warmup_period()

    if should_spin then
        if not spin_active then
            save_spin_settings()
        end
        apply_spin_settings()
    else
        restore_spin_settings()
    end
end

client.set_event_callback("setup_command", function(cmd)
    anti_aim.run(cmd)
    handle_spin_features(cmd)
end)



client.set_event_callback("shutdown", function()

    client.set_cvar("viewmodel_offset_x", 1)
    client.set_cvar("viewmodel_offset_y", 1)
    client.set_cvar("viewmodel_offset_z", -1)
    client.set_cvar("viewmodel_fov", 60)
    
  
    vars.visuals.references.scope_overlay:override()
    
    pui.traverse(vars.anti_aim.references.elements, function(item)
        item:set_visible(true)
    end)
end)
