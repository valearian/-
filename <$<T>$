        if globals.realtime() - log.time < 1.5 and i <= 6 then
            log.alpha = animations.lerp(log.alpha, 255, globals.frametime() * 6)
        end
        
        if globals.realtime() - log.time > 6 or i > 6 then
            log.alpha = animations.lerp(log.alpha, 0, globals.frametime() * 6)
            if log.alpha <= 5 then
                table.remove(misc.screen_indicators.logs, i)
            end
        end
        
        if #misc.screen_indicators.logs > 6 then
            misc.screen_indicators.logs[#misc.screen_indicators.logs].alpha = 
                animations.lerp(misc.screen_indicators.logs[#misc.screen_indicators.logs].alpha, 0, globals.frametime() * 6)
            if math.floor(misc.screen_indicators.logs[#misc.screen_indicators.logs].alpha) <= 0.05 then
                table.remove(misc.screen_indicators.logs, #misc.screen_indicators.logs)
            end
        end

        local log_color_r, log_color_g, log_color_b, log_color_a = menu.other.misc.screen_logs_color:get()
        local damage_color_r, damage_color_g, damage_color_b = menu.other.misc.aimbot_damage_color:get()
        local miss_color_r, miss_color_g, miss_color_b = menu.other.misc.aimbot_miss_color:get()
        
        if log.type == "hit" then
            local prefix = "[" .. prefix_icon .. log.prefix .. "] "
            local text1 = "Damage given to " .. log.target .. "'s " .. log.hitgroup .. " ~ "
            local damage_text = tostring(log.damage)
            local text2 = " (" .. log.hp .. ") [HT: " .. log.hitchance .. "% ~ | ~ BT: " .. log.backtrack .. "]"
            
            local prefix_w = renderer.measure_text(nil, prefix)
            local text1_w = renderer.measure_text(nil, text1)
            local damage_w = renderer.measure_text(nil, damage_text)
            local text2_w = renderer.measure_text(nil, text2)
            
            local total_w = prefix_w + text1_w + damage_w + text2_w
            local start_x = x - total_w / 2
            
            renderer.text(start_x, y + y_add, log_color_r, log_color_g, log_color_b, log.alpha, nil, 0, prefix)
            start_x = start_x + prefix_w
            
            renderer.text(start_x, y + y_add, 255, 255, 255, log.alpha, nil, 0, text1)
            start_x = start_x + text1_w
            
            renderer.text(start_x, y + y_add, damage_color_r, damage_color_g, damage_color_b, log.alpha, nil, 0, damage_text)
            start_x = start_x + damage_w
            
            renderer.text(start_x, y + y_add, 255, 255, 255, log.alpha, nil, 0, text2)
            
        elseif log.type == "miss" then
            local prefix = "[" .. prefix_icon .. log.prefix .. "] "
            local text1 = "Missed in " .. log.target .. "'s " .. log.hitgroup .. " due to "
            local reason_text = log.reason
            local text2 = " [HT: " .. log.hitchance .. "% ~ | ~ DMG: " .. log.damage .. " ~ | ~ BT: " .. log.backtrack .. "]"
            
            local prefix_w = renderer.measure_text(nil, prefix)
            local text1_w = renderer.measure_text(nil, text1)
            local reason_w = renderer.measure_text(nil, reason_text)
            local text2_w = renderer.measure_text(nil, text2)
            
            local total_w = prefix_w + text1_w + reason_w + text2_w
            local start_x = x - total_w / 2
            
            renderer.text(start_x, y + y_add, log_color_r, log_color_g, log_color_b, log.alpha, nil, 0, prefix)
            start_x = start_x + prefix_w
            
            renderer.text(start_x, y + y_add, 255, 255, 255, log.alpha, nil, 0, text1)
            start_x = start_x + text1_w
            
            renderer.text(start_x, y + y_add, miss_color_r, miss_color_g, miss_color_b, log.alpha, nil, 0, reason_text)
            start_x = start_x + reason_w
            
            renderer.text(start_x, y + y_add, 255, 255, 255, log.alpha, nil, 0, text2)
            
        elseif log.type == "death" then
            local text = "Killed by " .. log.attacker
            local text_w = renderer.measure_text(nil, text)
            renderer.text(x - text_w / 2, y + y_add, 255, 255, 255, log.alpha, nil, 0, text)
        end

        y_add = y_add + 15
    end
end

