                    renderer.text(visuals.slowed_down.data.x, bar_y + text_height * 2 - 4, 255, 255, 255, hint_alpha, "c", 0, "Click RMB to Default position")
                end
                
          
                if mx > visuals.slowed_down.data.x - 50 and mx < visuals.slowed_down.data.x + 50 and my > visuals.slowed_down.data.y - 24 and my < visuals.slowed_down.data.y + 24 then
