function misc.screen_indicators.add_hit(e)
    if not menu.other.misc.aimbot_logs:get() then return end
    
    local target_name = entity.get_player_name(e.target)
    local hitgroup = misc.screen_indicators.hitboxes[e.hitgroup + 1] or 'body'
    local damage = e.damage
    local remaining_hp = entity.get_prop(e.target, "m_iHealth") or 0
    local hitchance = math.floor(e.hit_chance or 0)
    
    local shot_data = misc.aimbot_logs.shots[e.id]
    local backtrack = shot_data and shot_data.backtrack or 0
    
    local prefix = "Sytheris"
    if menu.other.misc.custom_prefix:get() then
        prefix = menu.other.misc.logs_prefix:get()
        if prefix == "" then prefix = "Sytheris" end
    end
    
    local ar, ag, ab = menu.other.misc.aimbot_logs_color:get()
    local r, g, b = menu.other.misc.aimbot_damage_color:get()
    
    client.color_log(ar, ag, ab, "[" .. prefix .. "] Damage given to \0")
    client.color_log(r, g, b, target_name .. "\0")
    client.color_log(ar, ag, ab, "'s \0")
    client.color_log(r, g, b, hitgroup .. " \0")
    client.color_log(ar, ag, ab, "~ \0")
    client.color_log(r, g, b, damage .. " \0")
    client.color_log(ar, ag, ab, "(" .. remaining_hp .. ") [HT: \0")
    client.color_log(r, g, b, hitchance .. "% \0")
    client.color_log(ar, ag, ab, "~ | ~ BT: \0")
    client.color_log(r, g, b, backtrack .. "\0")
    client.color_log(ar, ag, ab, "]")
    
    if menu.other.misc.screen_logs:get() then
        table.insert(misc.screen_indicators.logs, 1, {
            type = "hit",
            target = target_name,
            hitgroup = hitgroup,
            damage = damage,
            hp = remaining_hp,
            hitchance = hitchance,
            backtrack = backtrack,
            prefix = prefix,
            alpha = 0,
            time = globals.realtime()
        })
    end
    
 
    if shot_data then
