local anti_aim = {} do
    anti_aim.data = {
        state_id = 0,
        inverter = false,
        ticks = 0,
        switch = false,
        lr_ticks = 0,
        lr_switch = false,
        manual_yaw_direction = 0,
        last_pushed_button = 0,
        dt_was_disabled = true,
        dt_ticking = 0,
        dt_tickbase = nil,
        pitch = "Off",
        yaw = {
            base = "At targets",
            degree = -180,
            jitter = {
                type = "Off",
                amount = 0
            }
        },
        body_yaw = {
            type = "Off",
            amount = 0
        },
        freestanding = false
    }

    anti_aim.condition_func = {
        onground_ticks = 0,
        on_ground = function (indx, limit)
            local flags = entity.get_prop(indx, "m_fFlags")

            if not bit.band(flags, 1) == 0 then return false end

            local onground = bit.band(flags, 1)

            if onground == 1 then
                anti_aim.condition_func.onground_ticks = anti_aim.condition_func.onground_ticks + 1
            else
                anti_aim.condition_func.onground_ticks = 0
            end

            return anti_aim.condition_func.onground_ticks > limit
        end,
        velocity = function(indx)
            local vel_x, vel_y = entity.get_prop(indx, "m_vecVelocity")
            local velocity = math.sqrt(vel_x * vel_x + vel_y * vel_y)
            return velocity
        end,
        is_crouching = function (indx)
            return entity.get_prop(indx, "m_flDuckAmount") > 0.8
        end
    }

    anti_aim.get_desync_side = function(cmd)
        local lp = entity.get_local_player()
        if lp == nil then return end

        local body_yaw = entity.get_prop(lp, "m_flPoseParameter", 11) * 120 - 60
        return body_yaw > 0
    end

    anti_aim.get_state = function()
        local lp = entity.get_local_player()
        if lp == nil then return end

        if anti_aim.data.manual_yaw_direction ~= 0 then
            return 10
        end

        local freestand_hotkey = menu.anti_aim.freestand_hotkey:get()

        if freestand_hotkey then
            return 9
        end

        if not anti_aim.condition_func.on_ground(lp, 5) then
            if anti_aim.condition_func.is_crouching(lp) then
                return 5
            else
                return 4
            end
        end

        local fake_duck_state = vars.anti_aim.references.elements.fake_duck:get()

        if anti_aim.condition_func.is_crouching(lp) or fake_duck_state then
            if anti_aim.condition_func.velocity(lp) > 4 then
                return 7
            else
                return 6
            end
        end

        local slow_motion_state = vars.anti_aim.references.elements.slow_motion.hotkey:get()

        if slow_motion_state then
            return 8
        end

        if anti_aim.condition_func.velocity(lp) > 4 then
            return 3
        end

        return 2
    end

    anti_aim.jitter_handle = function(cmd, mode, yaw, amount)
        local _amount = math.abs(amount)
        if yaw == nil then
            return {0, 0}
        end

        if mode == "Off" then
            return {yaw, yaw}
        elseif mode == "Offset" then
            return {yaw + amount, yaw + amount}
        elseif mode == "Center" then
            return {yaw - _amount, yaw + _amount}
        elseif mode == "Random" then
            local _ran = math.random(-_amount, _amount)
            return {yaw + _ran, yaw + _ran}
        elseif mode == "L & R" then
            return {yaw, yaw} 
        end
        
        return {yaw, yaw}
    end

    anti_aim.run = function(cmd)
        local lp = entity.get_local_player()
        if lp == nil or not entity.is_alive(lp) then return end

        if cmd.chokedcommands ~= 0 then return end

        local state_id = anti_aim.get_state()

        if menu.anti_aim.builder[state_id].enable_state.value == false and state_id ~= 1 then
            state_id = 1
        end

        anti_aim.data.pitch = menu.anti_aim.builder[state_id].pitch.value
        anti_aim.data.yaw.type = "180"
        anti_aim.data.yaw.base = "At targets"

        anti_aim.data.inverter = anti_aim.get_desync_side(cmd)

        if globals.chokedcommands() == 0 then
            local base_yaw = menu.anti_aim.builder[state_id].yaw_amount:get()
            
            if menu.anti_aim.builder[state_id].yaw_lr_mode:get() == "Left/Right" then
                base_yaw = (anti_aim.data.inverter and menu.anti_aim.builder[state_id].yaw_left:get() or menu.anti_aim.builder[state_id].yaw_right:get()) + base_yaw
            end
            
          
            anti_aim.data.yaw.jitter.type = "Off"
            anti_aim.data.yaw.jitter.amount = 0
            
           
            local yaw_modifier_mode = menu.anti_aim.builder[state_id].yaw_modifier:get()
            local yaw_modifier_amount = menu.anti_aim.builder[state_id].yaw_modifier_amount:get()
            
            if yaw_modifier_mode == "L & R" then
                local left_mod = menu.anti_aim.builder[state_id].yaw_modifier_left:get()
                local right_mod = menu.anti_aim.builder[state_id].yaw_modifier_right:get()
                base_yaw = base_yaw + (anti_aim.data.inverter and left_mod or right_mod)
            elseif yaw_modifier_mode == "Skitter" or yaw_modifier_mode == "Center" then
            
                local jitter_amount = math.abs(yaw_modifier_amount)
                local randomizer = menu.anti_aim.builder[state_id].yaw_randomizer:get()
                
                if jitter_amount > 0 and randomizer > 0 then
                    local roll = client.random_int(1, 100)
                    if roll <= randomizer then
                        jitter_amount = math.max(0, jitter_amount - 1)
                    end
                end
                
                if yaw_modifier_mode == "Center" then
                    anti_aim.data.yaw.jitter.type = "Center"
                    anti_aim.data.yaw.jitter.amount = jitter_amount
                elseif yaw_modifier_mode == "Skitter" then
                    anti_aim.data.yaw.jitter.type = "Skitter"
                    anti_aim.data.yaw.jitter.amount = jitter_amount
                end
            else
                local modifier_result = anti_aim.jitter_handle(cmd, yaw_modifier_mode, base_yaw, yaw_modifier_amount)
                base_yaw = anti_aim.data.inverter and modifier_result[1] or modifier_result[2]
            end
            
            anti_aim.data.yaw.degree = base_yaw
        end

        local body_mode = menu.anti_aim.builder[state_id].body_yaw:get()

        if body_mode == "Jitter" then
            anti_aim.data.body_yaw.type = "Jitter"
            anti_aim.data.body_yaw.amount = menu.anti_aim.builder[state_id].body_yaw_jitter:get()
        elseif body_mode == "L & R Jitter" then
            anti_aim.data.body_yaw.type = "Jitter"
            local left = menu.anti_aim.builder[state_id].body_yaw_left:get()
            local right = menu.anti_aim.builder[state_id].body_yaw_right:get()
            anti_aim.data.body_yaw.amount = anti_aim.data.inverter and left or right
        else
            anti_aim.data.body_yaw.type = body_mode
            anti_aim.data.body_yaw.amount = -1
        end

        anti_aim.data.freestanding = menu.anti_aim.freestand_hotkey:get()
        
        if anti_aim.data.manual_yaw_direction ~= 0 then
            vars.anti_aim.references.elements.freeStand:set(false)
        else
            vars.anti_aim.references.elements.freeStand:set(anti_aim.data.freestanding)
        end

        if menu.anti_aim.manual_yaw_right:get() and anti_aim.data.last_pushed_button + 0.1 < globals.curtime() then
            anti_aim.data.manual_yaw_direction = anti_aim.data.manual_yaw_direction == 2 and 0 or 2
            anti_aim.data.last_pushed_button = globals.curtime()
        elseif menu.anti_aim.manual_yaw_left:get() and anti_aim.data.last_pushed_button + 0.1 < globals.curtime() then
            anti_aim.data.manual_yaw_direction = anti_aim.data.manual_yaw_direction == 1 and 0 or 1
            anti_aim.data.last_pushed_button = globals.curtime()
        elseif menu.anti_aim.manual_yaw_forward:get() and anti_aim.data.last_pushed_button + 0.1 < globals.curtime() then
            anti_aim.data.manual_yaw_direction = anti_aim.data.manual_yaw_direction == 3 and 0 or 3
            anti_aim.data.last_pushed_button = globals.curtime()
        elseif anti_aim.data.last_pushed_button > globals.curtime() then
            anti_aim.data.last_pushed_button = globals.curtime()
        end

        if anti_aim.data.manual_yaw_direction == 1 then
            anti_aim.data.yaw.degree = -90
        elseif anti_aim.data.manual_yaw_direction == 2 then
            anti_aim.data.yaw.degree = 90
        elseif anti_aim.data.manual_yaw_direction == 3 then
            anti_aim.data.yaw.degree = 180
        end

        anti_aim.avoid_backstab = {}
        anti_aim.avoid_backstab.run = function(cmd)
            if not menu.anti_aim.tweaks:get("Avoid backstab") then return end

            local lp = entity.get_local_player()
            if lp == nil or not entity.is_alive(lp) then return end

            local enemies = entity.get_players(true)
            if #enemies == 0 then return end

            for _, enemy in ipairs(enemies) do
                if entity.is_alive(enemy) then
                    local weapon = entity.get_player_weapon(enemy)
                    if weapon ~= nil and entity.get_classname(weapon) == "CKnife" then
                        local ex, ey, ez = entity.get_prop(enemy, "m_vecOrigin")
                        local lx, ly, lz = entity.get_prop(lp, "m_vecOrigin")
                        
                        if ex ~= nil and lx ~= nil then
                         
                            local vel_x, vel_y, vel_z = entity.get_prop(lp, "m_vecVelocity")
                            
                            for ticks = 1, 9 do
                                local tickinterval = globals.tickinterval()
                                local tex = lx + vel_x * ticks * tickinterval
                                local tey = ly + vel_y * ticks * tickinterval
                                local tez = lz + vel_z * ticks * tickinterval
                                
                                local dx = ex - tex
                                local dy = ey - tey
                                local dz = ez - tez
                                local distance = math.sqrt(dx * dx + dy * dy + dz * dz)
                                
                                if distance < menu.anti_aim.avoid_backstab_distance:get() then
                                    anti_aim.data.yaw.base = "At targets"
                                    anti_aim.data.yaw.degree = 180
                                    anti_aim.data.yaw.jitter.type = "Off"
                                    anti_aim.data.yaw.jitter.amount = 0
                                    anti_aim.data.freestanding = false
                                    return
                                end
                            end
                        end
                    end
                end
            end
        end

        anti_aim.avoid_backstab.run(cmd)

        anti_aim.safe_head = {}
        anti_aim.safe_head.run = function(cmd)
            if not menu.anti_aim.tweaks:get("Safe head") then return end

            local lp = entity.get_local_player()
            if lp == nil or not entity.is_alive(lp) then return end

            local flags = entity.get_prop(lp, "m_fFlags")
            local on_ground = bit.band(flags, 1) == 1
            local jumping = not on_ground

            if jumping or not on_ground then
                local weapon = entity.get_player_weapon(lp)
                if weapon ~= nil then
                    local weapon_name = entity.get_classname(weapon)
                    local should_apply = false
                    
                    if weapon_name == "CKnife" and menu.anti_aim.safe_head_weapons:get(" Knife") then
                        should_apply = true
                    elseif weapon_name == "CWeaponTaser" and menu.anti_aim.safe_head_weapons:get(" Zeus") then
                        should_apply = true
                    end
                    
                    if should_apply then
                        anti_aim.data.pitch = "Down"
                    end
                end
            end
        end

        anti_aim.safe_head.run(cmd)

        anti_aim.air_exploit = {}
        anti_aim.air_exploit.reset = false
        
        anti_aim.air_exploit.backups = function()
            if anti_aim.air_exploit.reset then
                local aimbot_ref = ui.reference("RAGE", "Aimbot", "Enabled")
                local duck_peek_ref = ui.reference("RAGE", "Other", "Duck peek assist")
                local fakelag_limit_ref = ui.reference("AA", "Fake lag", "Limit")
                local sv_maxusrcmd_ref = ui.reference("Misc", "Settings", "sv_maxusrcmdprocessticks2")
                
                ui.set(aimbot_ref, true)
                ui.set(duck_peek_ref, "On hotkey")
                
               
                if fakelag_limit_ref then
                    ui.set(fakelag_limit_ref, 14)
                end
                if sv_maxusrcmd_ref then
                    ui.set(sv_maxusrcmd_ref, 16)
                end
                
                anti_aim.air_exploit.reset = false
            end
        end
        
        anti_aim.air_exploit.run = function(cmd)
            if not menu.anti_aim.tweaks:get("Air lag exploit") then
                return anti_aim.air_exploit.backups()
            end

           
            if not menu.anti_aim.air_exploit_hotkey:get() then
                return anti_aim.air_exploit.backups()
            end

            local dt_ref1, dt_ref2 = ui.reference("RAGE", "Aimbot", "Double tap")
            local dt_enabled = ui.get(dt_ref1)
            local dt_hotkey = ui.get(dt_ref2)
            
            if not (dt_enabled and dt_hotkey) then
                return anti_aim.air_exploit.backups()
            end

            local flags = entity.get_prop(lp, "m_fFlags")
            local on_ground = bit.band(flags, 1) == 1
            
            if on_ground then
                return anti_aim.air_exploit.backups()
            end

         
            local aimbot_ref = ui.reference("RAGE", "Aimbot", "Enabled")
            local duck_peek_ref = ui.reference("RAGE", "Other", "Duck peek assist")
            local fakelag_limit_ref = ui.reference("AA", "Fake lag", "Limit")
            local sv_maxusrcmd_ref = ui.reference("Misc", "Settings", "sv_maxusrcmdprocessticks2")
            
          
            if sv_maxusrcmd_ref then
                ui.set(sv_maxusrcmd_ref, 19)
            end
            if fakelag_limit_ref then
                ui.set(fakelag_limit_ref, 17)
            end

            local tickbase = entity.get_prop(lp, "m_nTickBase")
            local shift_active = false
            if tickbase then
                shift_active = math.abs(tickbase - globals.tickcount()) > 0
            end

  
            if shift_active then
        
                ui.set(aimbot_ref, true)
                cmd.discharge_pending = true
            else
             
                ui.set(aimbot_ref, false)
                local ticks = menu.anti_aim.air_exploit_ticks:get()
                ui.set(duck_peek_ref, globals.tickcount() % ticks == 0 and "Always on" or "On hotkey")
            end

            anti_aim.air_exploit.reset = true
        end

        anti_aim.air_exploit.run(cmd)

        local yaw_degree = anti_aim.data.yaw.degree
        if yaw_degree > 180 then
            yaw_degree = yaw_degree - 360
        elseif yaw_degree < -180 then
            yaw_degree = yaw_degree + 360
        end

        vars.anti_aim.references.elements.pitch[1]:set(anti_aim.data.pitch)
        vars.anti_aim.references.elements.yaw[1]:set(anti_aim.data.yaw.type)
        vars.anti_aim.references.elements.yaw[2]:set(yaw_degree)
        vars.anti_aim.references.elements.yawbase:set(anti_aim.data.yaw.base)
