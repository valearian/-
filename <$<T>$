    visuals.manual_arrows = {} do
        visuals.manual_arrows.data = {
            alpha = 0,
            x = 0
        }

        local function draw_romance_arrow(x, y, width, height, direction, color, edge_alpha)
            local dirc = direction == 1 and (x + width) or (x - width)

            for i = (height/2 - height), height/2 do
                renderer.line(x, y, dirc, y + i, color[1], color[2], color[3], math_floor(color[4] * 0.5))
            end

            local a = math_floor(edge_alpha)
            renderer.line(x, y, dirc, y + height/2, color[1], color[2], color[3], a)
            renderer.line(x, y, dirc, y - height/2, color[1], color[2], color[3], a)
            renderer.line(dirc, y - height/2, dirc, y + height/2, color[1], color[2], color[3], a)
        end

        visuals.manual_arrows.paint = function(c)
            if not menu.other.visuals.manual_arrows:get() then return end

            local lp = entity.get_local_player()
            if lp == nil or not entity.is_alive(lp) then return end

            local main_color = {255, 255, 255, 255}
            local disabled_color = { 255, 255, 255, 150 }

            local arrows_color_left = anti_aim.data.manual_yaw_direction == 1 and main_color or disabled_color
            local arrows_color_right = anti_aim.data.manual_yaw_direction == 2 and main_color or disabled_color

            local style = menu.other.visuals.manual_arrows_style:get()

            if style == "Sytheris" then
                local scoped = entity.get_prop(lp, "m_bIsScoped") == 1
                local lerpSpeed = globals.frametime() * 30
                local target_alpha = scoped and 0 or 255
                visuals.manual_arrows.data.alpha = animations.lerp(visuals.manual_arrows.data.alpha, target_alpha, lerpSpeed * 0.35)
                local a = visuals.manual_arrows.data.alpha

                local r, g, b, ca = menu.other.visuals.crosshair_indicators_color:get()
                local active = {r, g, b, a}
                local inactive = {110, 110, 110, math_floor(a * 0.55)}

                local sw, sh = client.screen_size()
                local cx, cy = math_floor(sw/2), math_floor(sh/2)
                local padding = 26
                local height = 12
                local width = 13

                local left_on = anti_aim.data.manual_yaw_direction == 1
                local right_on = anti_aim.data.manual_yaw_direction == 2

                draw_romance_arrow(cx - 36 - padding, cy, width, height, 1, left_on and active or inactive, a)
                draw_romance_arrow(cx + 36 + padding, cy, width, height, 2, right_on and active or inactive, a)
            else
                local classic_style = style == "Classic"
                local measure_arrow = renderer.measure_text(classic_style and "+" or "", classic_style and ">" or "❱")

                renderer.text(screen_x / 2 + 40, screen_y / 2 -  (classic_style and 16 or 7), arrows_color_right[1], arrows_color_right[2], arrows_color_right[3], arrows_color_right[4], classic_style and "+" or "", 0, classic_style and ">" or "❱")
                renderer.text(screen_x / 2 - measure_arrow / 2 - 41, screen_y / 2 - (classic_style and 16 or 7), arrows_color_left[1], arrows_color_left[2], arrows_color_left[3], arrows_color_left[4], classic_style and "+" or "", 0, classic_style and "<" or "❰")
            end
        end
    end

