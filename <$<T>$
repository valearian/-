local menu_depends do
    menu.anti_aim.tweaks_slider:set_callback(function(self)
        local value = self:get()

 
        if value == 0 then
            menu.anti_aim.tweaks:set({})
            menu.anti_aim.tweaks:set({"Avoid backstab"})
        elseif value == 1 then
            menu.anti_aim.tweaks:set({})
            menu.anti_aim.tweaks:set({"Safe head"})
        end
    end)

    for k, v in ipairs(vars.anti_aim.states) do
        local is_state = { menu.anti_aim.current_state, vars.anti_aim.states[k] }
        local is_state_enabled = { menu.anti_aim.builder[k].enable_state, function() if k == 1 then return true else return menu.anti_aim.builder[k].enable_state.value end end }
        local can_enable_state = { menu.anti_aim.builder[k].enable_state, function() return k ~= 1 end }

        local is_left_right = { menu.anti_aim.builder[k].yaw_lr_mode, "Left/Right" }
        local is_pitch_enabled = { menu.anti_aim.builder[k].pitch, function() return menu.anti_aim.builder[k].pitch.value ~= "Off" end }

        local is_yaw_modifier = { menu.anti_aim.builder[k].yaw_modifier, function() return menu.anti_aim.builder[k].yaw_modifier.value ~= "Off" end }
        local is_yaw_modifier_lr = { menu.anti_aim.builder[k].yaw_modifier, function() return menu.anti_aim.builder[k].yaw_modifier.value == "L & R" end }
        local is_yaw_modifier_not_lr = { menu.anti_aim.builder[k].yaw_modifier, function() 
            local val = menu.anti_aim.builder[k].yaw_modifier.value
            return val ~= "Off" and val ~= "L & R" and val ~= "Skitter"
        end }
        local is_yaw_modifier_randomizer = { menu.anti_aim.builder[k].yaw_modifier, function()
            local val = menu.anti_aim.builder[k].yaw_modifier.value
            return val == "Center" or val == "Skitter"
        end }

        local is_body_yaw = { menu.anti_aim.builder[k].body_yaw, function() return menu.anti_aim.builder[k].body_yaw.value ~= "Off" end }
        local is_jitter_body = { menu.anti_aim.builder[k].body_yaw, function() return menu.anti_aim.builder[k].body_yaw.value == "Jitter" end }
        local is_lr_jitter_body = { menu.anti_aim.builder[k].body_yaw, function() return menu.anti_aim.builder[k].body_yaw.value == "L & R Jitter" end }

        menu.anti_aim.builder[k].enable_state:depend( is_state, can_enable_state )
        menu.anti_aim.builder[k].pitch:depend( is_state, is_state_enabled )
        menu.anti_aim.builder[k].yaw_amount:depend( is_state, is_state_enabled, is_pitch_enabled )
        menu.anti_aim.builder[k].yaw_lr_mode:depend( is_state, is_state_enabled )
        menu.anti_aim.builder[k].yaw_left:depend( is_state, is_state_enabled, is_left_right )
        menu.anti_aim.builder[k].yaw_right:depend( is_state, is_state_enabled, is_left_right )
        menu.anti_aim.builder[k].yaw_modifier:depend( is_state, is_state_enabled )
        menu.anti_aim.builder[k].yaw_modifier_amount:depend( is_state, is_state_enabled, is_yaw_modifier_not_lr )
        menu.anti_aim.builder[k].yaw_modifier_left:depend( is_state, is_state_enabled, is_yaw_modifier_lr )
        menu.anti_aim.builder[k].yaw_modifier_right:depend( is_state, is_state_enabled, is_yaw_modifier_lr )
        menu.anti_aim.builder[k].yaw_randomizer:depend( is_state, is_state_enabled, is_yaw_modifier_randomizer )
        menu.anti_aim.builder[k].body_yaw:depend( is_state, is_state_enabled )
        menu.anti_aim.builder[k].body_yaw_left:depend( is_state, is_state_enabled, is_body_yaw, is_lr_jitter_body )
        menu.anti_aim.builder[k].body_yaw_right:depend( is_state, is_state_enabled, is_body_yaw, is_lr_jitter_body )
        menu.anti_aim.builder[k].body_yaw_jitter:depend( is_state, is_state_enabled, is_body_yaw, is_jitter_body )
    end
end

