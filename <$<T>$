local function is_warmup_period()
    local game_rules = entity.get_all("CCSGameRulesProxy")
    if not game_rules or #game_rules == 0 then
        return false
    end

    local warmup_flag = entity.get_prop(game_rules[1], "m_bWarmupPeriod")
    if warmup_flag == nil then
        return false
    end

    return warmup_flag == true or warmup_flag == 1
end

