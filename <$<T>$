    if refs.pitch and refs.pitch[1] and spin_saved_settings.pitch then
        refs.pitch[1]:set(spin_saved_settings.pitch)
    end
    if refs.yaw and refs.yaw[1] and spin_saved_settings.yaw then
        refs.yaw[1]:set(spin_saved_settings.yaw)
    end
    if refs.yaw and refs.yaw[2] and spin_saved_settings.yaw_amount then
        refs.yaw[2]:set(spin_saved_settings.yaw_amount)
    end
    if refs.yawjitter and refs.yawjitter[1] and spin_saved_settings.yawjitter then
