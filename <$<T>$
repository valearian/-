            end
        end
    end
    
    local function reset_cvars()
        for cvar_name, cvar_value in pairs(default_cvars) do
            if cvar_value ~= nil then
                pcall(function() client.set_cvar(cvar_name, cvar_value) end)
            end
        end
    end
    
    menu.other.misc.fps_boost:set_callback(function(self)
        if self:get() then
            apply_fps_boost()
        else
            reset_cvars()
        end
    end)
    
    menu.other.misc.fps_boost_options:set_callback(function()
