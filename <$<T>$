            renderer.rectangle(bar_x, bar_y, bar_width, bar_height, 15, 15, 15, math.floor(alpha_mult * 100))
            
          
            local fill_width = (bar_width - 2) / 100 * math.floor(visuals.slowed_down.data.val)
            renderer.rectangle(bar_x + 1, bar_y + 1, fill_width, bar_height - 2, cr, cg, cb, math.floor(alpha_mult * ca))
            
           
            local text_start_x = visuals.slowed_down.data.x - total_width / 2
            renderer.text(text_start_x, bar_y - text_height, 255, 255, 255, math.floor(alpha_mult * 255), nil, 0, text_label)
            
      
            renderer.text(text_start_x + label_width, bar_y - text_height, cr, cg, cb, math.floor(alpha_mult * 255), nil, 0, text_percent)
            
         
            if ui.is_menu_open() then
